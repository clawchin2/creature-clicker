{
  "name": "CreatureClicker",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage"
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Main": { "$path": "creature-clicker/ServerScriptService/Main.server.lua" },
      "Modules": {
        "$className": "Folder",
        "CreatureConfig": { "$path": "creature-clicker/ServerScriptService/Modules/CreatureConfig.lua" },
        "PlayerData": { "$path": "creature-clicker/ServerScriptService/Modules/PlayerData.lua" },
        "ClickHandler": { "$path": "creature-clicker/ServerScriptService/Modules/ClickHandler.lua" },
        "HatchSystem": { "$path": "creature-clicker/ServerScriptService/Modules/HatchSystem.lua" },
        "PassiveIncome": { "$path": "creature-clicker/ServerScriptService/Modules/PassiveIncome.lua" }
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "ClickerUI": { "$path": "src/client/ClickerUI.lua" },
        "HatchShopUI": { "$path": "src/client/HatchShopUI.lua" }
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "SpawnLocation": { "$className": "SpawnLocation", "$properties": { "Position": [0, 10, 0] } }
    }
  }
}
